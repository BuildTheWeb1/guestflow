# =============================================================================
# GuestFlow — AutoPilot Ospitalitate
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER commit
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/

# -----------------------------------------------------------------------------
# Docker Volume Data — large, machine-specific, regenerated on startup
# -----------------------------------------------------------------------------
n8n-data/
postgres-data/

# -----------------------------------------------------------------------------
# n8n exports / backups (may contain credentials)
# -----------------------------------------------------------------------------
*.n8n-backup
n8n-export/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Node.js (if scripts are added)
# -----------------------------------------------------------------------------
node_modules/
.npm
.yarn/

# -----------------------------------------------------------------------------
# Python (if scripts are added)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.suo
.history/

# -----------------------------------------------------------------------------
# Temporary / OS
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*~

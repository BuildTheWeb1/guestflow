# =============================================================================
# AutoPilot Ospitalitate — Demo Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values before running.
#
#   cp .env.example .env
#
# These credentials are for LOCAL DEMO USE ONLY.
# Never commit .env to git. Never reuse these passwords in production.
# =============================================================================


# -----------------------------------------------------------------------------
# ngrok — Public tunnel to localhost
# -----------------------------------------------------------------------------
# Your free static domain from dashboard.ngrok.com → Domains → New Domain
# Example: fox-happy-lion.ngrok-free.app
# Do NOT include https:// — just the hostname.
NGROK_STATIC_DOMAIN=your-static-domain.ngrok-free.app


# -----------------------------------------------------------------------------
# PostgreSQL — n8n internal database (runs in Docker, never exposed publicly)
# -----------------------------------------------------------------------------
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=changeme_local_only_not_for_production


# -----------------------------------------------------------------------------
# n8n — Encryption key for stored credentials
# -----------------------------------------------------------------------------
# IMPORTANT: Must be exactly 32 characters. Generate with:
#   openssl rand -hex 16
# Once set, do NOT change this — it will break all saved credentials.
N8N_ENCRYPTION_KEY=demo_key_32chars_changeme_local1


# -----------------------------------------------------------------------------
# Claude / Anthropic — AI responses
# -----------------------------------------------------------------------------
# Get your key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Supabase — Guest database (cloud, free tier)
# -----------------------------------------------------------------------------
# Project URL from: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key (has admin access — keep secret!)
# From: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Meta / WhatsApp Cloud API
# -----------------------------------------------------------------------------
# App Secret from: Meta Developer → Your App → Settings → Basic → App Secret
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verify token — you choose this value. Must match what you enter in Meta's
# webhook configuration screen (Callback URL verification step).
META_VERIFY_TOKEN=autopilot-demo-verify-2024

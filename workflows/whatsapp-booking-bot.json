    {
      "id": "node-parse-message",
      "name": "Parse WhatsApp Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        380
      ],
      "parameters": {
        "jsCode": "// Extract the inbound message from the Meta webhook payload.\n// Meta sends a nested structure: body.entry[0].changes[0].value.messages[0]\nconst rawInput = $input.item.json.body;\nconst body = typeof rawInput === 'string' ? JSON.parse(rawInput) : rawInput;\n\nlet messageText = null;\nlet senderPhone = null;\nlet phoneNumberId = null;\nlet messageId = null;\n\ntry {\n  const entry = body.entry?.[0];\n  const change = entry?.changes?.[0];\n  const value = change?.value;\n  const message = value?.messages?.[0];\n  const contact = value?.contacts?.[0];\n\n  messageText = message?.text?.body || message?.interactive?.button_reply?.title || null;\n  senderPhone = message?.from || null;\n  phoneNumberId = value?.metadata?.phone_number_id || null;\n  messageId = message?.id || null;\n} catch (e) {\n  // Payload parsing failed — return empty so downstream IF node drops it\n}\n\nreturn [\n  {\n    json: {\n      messageText,\n      senderPhone,\n      phoneNumberId,\n      messageId,\n      rawBody: body\n    }\n  }\n];"
      }
    },

    {
      "id": "node-manage-conversation",
      "name": "Manage Conversation & Fetch History",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        300
      ],
      "parameters": {
        "jsCode": "const supabaseUrl = $env.SUPABASE_URL;\nconst key = $env.SUPABASE_SERVICE_ROLE_KEY;\nconst clientId = $json.clientId;\nconst senderPhone = $json.senderPhone;\nconst userMessage = $json.userMessage;\n\nconst headers = {\n  apikey: key,\n  Authorization: `Bearer ${key}`,\n  'Content-Type': 'application/json'\n};\n\n// 1. Find existing active conversation\nconst existing = await $helpers.httpRequest({\n  method: 'GET',\n  url: `${supabaseUrl}/rest/v1/conversations`,\n  headers: { apikey: key, Authorization: `Bearer ${key}` },\n  qs: {\n    client_id: `eq.${clientId}`,\n    guest_wa_number: `eq.${senderPhone}`,\n    status: 'eq.active',\n    select: 'id',\n    limit: '1'\n  }\n});\n\nlet conversationId;\nif (existing.length > 0) {\n  conversationId = existing[0].id;\n} else {\n  // 2. Create new conversation\n  const created = await $helpers.httpRequest({\n    method: 'POST',\n    url: `${supabaseUrl}/rest/v1/conversations`,\n    headers: { ...headers, Prefer: 'return=representation' },\n    body: {\n      client_id: clientId,\n      guest_wa_number: senderPhone,\n      status: 'active',\n      message_count: 0,\n      last_message_at: new Date().toISOString()\n    }\n  });\n  conversationId = created[0].id;\n}\n\n// 3. Save inbound message\nawait $helpers.httpRequest({\n  method: 'POST',\n  url: `${supabaseUrl}/rest/v1/messages`,\n  headers: { ...headers, Prefer: 'return=minimal' },\n  body: {\n    conversation_id: conversationId,\n    direction: 'inbound',\n    content: userMessage\n  }\n});\n\n// 4. Fetch last 10 messages for history\nconst history = await $helpers.httpRequest({\n  method: 'GET',\n  url: `${supabaseUrl}/rest/v1/messages`,\n  headers: { apikey: key, Authorization: `Bearer ${key}` },\n  qs: {\n    conversation_id: `eq.${conversationId}`,\n    order: 'created_at.asc',\n    limit: '11',\n    select: 'direction,content'\n  }\n});\n\n// Format as Claude multi-turn messages (drop last — it's the inbound just saved)\nconst claudeMessages = history.slice(0, -1).map(msg => ({\n  role: msg.direction === 'inbound' ? 'user' : 'assistant',\n  content: msg.content\n}));\nclaudeMessages.push({ role: 'user', content: userMessage });\n\nreturn [{ json: { ...$json, conversationId, claudeMessages } }];"
      }
